# ============================================
# ИГРОВОЙ ДВИЖОК НА C++ - СПЕЦИАЛИЗИРОВАННЫЙ .gitignore
# Для команды из 4 человек
# ============================================

# ============================================
# 1. СБОРКА (CMAKE)
# ============================================
# Папки сборки (полностью игнорируем)
build/
cmake-build-*/
out/
bin/              # Ваши бинарники (движок + игра)
bin-int/          # Промежуточные файлы (объектники)
[Bb]in/
[Oo]bj/

# Файлы CMake
CMakeLists.txt.user
CMakeCache.txt
CMakeFiles/
CMakeScripts/
Makefile
cmake_install.cmake
install_manifest.txt
compile_commands.json
CTestTestfile.cmake
_deps/
*.cmake
!CMakeLists.txt    # Исключение: сам CMakeLists.txt НЕ игнорируем

# ============================================
# 2. КОМПИЛЯТОРЫ И ЛИНКОВЩИКИ
# ============================================
# Объектные файлы
*.o
*.obj
*.ko
*.elf

# Прекомпилированные заголовки
*.gch
*.pch

# Статические библиотеки
*.a
*.la
*.lib
*.lai

# Динамические библиотеки
*.so
*.so.*
*.dylib
*.dll
*.dll.a

# Исполняемые файлы
*.exe
*.out
*.app
*.i*86
*.x86_64

# Файлы отладки
*.pdb
*.idb
*.ilk
*.map
*.exp
*.su
*.dSYM/

# ============================================
# 3. ИНТЕГРИРОВАННЫЕ СРЕДЫ РАЗРАБОТКИ (IDE)
# ============================================
# Visual Studio
.vs/
*.sln.docstates
*.suo
*.user
*.userosscache
*.rsuser
*.VC.db
*.VC.VC.opendb
*.opendb
*.opensdf
*.sdf
*.cachefile
ipch/
Generated Files/

# Visual Studio Code
.vscode/
*.code-workspace
.history/

# CLion
.idea/
*.iml
cmake-build-*/

# Qt Creator
*.pro.user
*.pro.user.*
*.autosave
CMakeLists.txt.user*

# ============================================
# 4. ЛОГИ И ВРЕМЕННЫЕ ФАЙЛЫ
# ============================================
*.log
*.tmp
*.temp
*.bak
*.orig
*~
*.stackdump

# ============================================
# 5. ОПЕРАЦИОННЫЕ СИСТЕМЫ
# ============================================
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk
*.cab
*.msi
*.msix
*.msm
*.msp

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
.fseventsd

# Linux
.directory
.Trash-*
.fuse_hidden*
.nfs*

# ============================================
# 6. СИСТЕМЫ КОНТРОЛЯ ВЕРСИЙ
# ============================================
.svn/
.hg/
.hgignore
.hgsigs
.hgsub
.hgsubstate
.hgtags
.bzr/
.bzrignore
/CVS/
**/CVS/
.cvsignore

# ============================================
# 7. РЕДАКТОРЫ И ИНСТРУМЕНТЫ
# ============================================
# Sublime Text
*.sublime-workspace
*.tmlanguage.cache
*.tmPreferences.cache
Package Control.last-run

# Vim
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
[._]s[a-rt-v][a-z]
[._]ss[a-gi-z]
[._]sw[a-p]
Session.vim
.netrwhist
tags

# Emacs
*~
\#*\#
/.emacs.desktop
*.elc
auto-save-list
tramp
.\#*

# ============================================
# 8. УПРАВЛЕНИЕ ЗАВИСИМОСТЯМИ
# ============================================
# vcpkg
vcpkg_installed/
vcpkg-manifest-install.log

# Conan
conaninfo.txt
conanbuildinfo.*
conanbuildinfo.mak
conan.lock

# ============================================
# 9. БИБЛИОТЕКИ ТРЕТЬИХ ЛИЦ (если скачиваете в проект)
# ============================================
# Обычно библиотеки лежат в отдельной папке
# Если вы скачиваете их в проект - раскомментируйте:
# external/
# libs/
# dependencies/

# ============================================
# 10. ИГРОВЫЕ РЕСУРСЫ (опционально)
# ============================================
# Если ресурсы генерируются во время сборки
# *.png
# *.jpg
# *.wav
# *.mp3
# *.fbx
# *.gltf

# ============================================
# 11. ВРЕМЕННЫЕ ФАЙЛЫ ДВИЖКА
# ============================================
# Шейдерный кеш
*.spv
*.cso
*.dxbc

# Физический кеш (если используете)
*.nvdb
*.bvh

# ============================================
# 12. ПАКЕТЫ И АРХИВЫ
# ============================================
*.zip
*.tar
*.gz
*.7z
*.rar

# ============================================
# 13. CI/CD (Continuous Integration)
# ============================================
.azure-pipelines/
.github/
.gitlab/
*.ci.yml
*.ci.yaml

# ============================================
# 14. ДОКУМЕНТАЦИЯ (если генерируется)
# ============================================
docs/_build/
docs/html/
docs/latex/
*.dox

# ============================================
# 15. ПРОФАЙЛИНГ
# ============================================
*.psess
*.vsp
*.vspx
*.sap
*.prof
*.gcda
*.gcno

# ============================================
# 16. РЕЗЕРВНЫЕ КОПИИ
# ============================================
*.orig
*.bak
*~
*.swp
*.swo

# ============================================
# 17. КЛЮЧИ И ПАРОЛИ
# ============================================
*.pem
*.key
*.crt
*.p12
*.pfx
*.snk
secrets/
*.secret

# ============================================
# 18. НАСТРОЙКИ ПОЛЬЗОВАТЕЛЯ
# ============================================
local.properties
.env
*.local
user_settings.json
config.local.*